/css/*.css
  Content-Type: text/css; charset=utf-8

/js/*.js
  Content-Type: application/javascript; charset=utf-8

/assets/img/*.webp
  Content-Type: image/webp

/assets/img/**/*.webp
  Content-Type: image/webp

/assets/img/*.svg
  Content-Type: image/svg+xml

/assets/img/**/*.svg
  Content-Type: image/svg+xml

/assets/img/*.png
  Content-Type: image/png

/assets/img/**/*.png
  Content-Type: image/png

/assets/img/*.jpg
  Content-Type: image/jpeg

/assets/img/**/*.jpg
  Content-Type: image/jpeg

/assets/img/*.jpeg
  Content-Type: image/jpeg

/assets/img/**/*.jpeg
  Content-Type: image/jpeg

/assets/fonts/*.ttf
  Content-Type: font/ttf

/assets/fonts/**/*.ttf
  Content-Type: font/ttf

/assets/fonts/*.woff2
  Content-Type: font/woff2

/assets/fonts/**/*.woff2
  Content-Type: font/woff2
